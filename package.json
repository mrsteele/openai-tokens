{
  "name": "openai-tokens",
  "version": "0.2.0",
  "description": "A service for calculating, managing, truncating openai prompt tokens",
  "type": "commonjs",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./models": {
      "types": "./src/models.d.ts",
      "require": "./src/models.js",
      "default": "./src/models.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "jest",
    "lint": "standard",
    "dev": "npm t -- --watch",
    "test:ci": "jest --runInBand"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrsteele/openai-tokens.git"
  },
  "files": [
    "/src/*",
    "!/src/*test.js"
  ],
  "keywords": [
    "openai",
    "gpt",
    "chatGPT",
    "token",
    "tokens",
    "tiktoken",
    "validate",
    "truncate",
    "models",
    "embeddings",
    "ada"
  ],
  "standard": {
    "env": [
      "jest"
    ]
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  },
  "author": "Matt Steele <hi@mrsteele.dev>",
  "license": "MIT",
  "dependencies": {
    "isomorphic-fetch": "^3.0.0",
    "js-tiktoken": "^1.0.14"
  },
  "devDependencies": {
    "jest": "^30.0.0",
    "standard": "^17.1.0"
  }
}
